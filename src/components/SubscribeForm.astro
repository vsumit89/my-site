---
---
<section
  id="subscribe"
  class="mt-14 p-6 bg-paper-2 border border-line rounded-lg text-center mobile:mt-10 mobile:p-5"
>
  <h3 class="font-serif text-2xl tracking-[-0.01em] mb-1 mt-0">Monthly notes.</h3>
  <p class="text-ink-soft text-nav mb-4 mt-0">
    One ship-report, one essay, once a month. No tracking, no spam.
  </p>
  <form
    class="flex gap-2 max-w-form mx-auto mobile:flex-col"
    action="#"
    method="post"
    onsubmit="return false;"
  >
    <input
      type="email"
      placeholder="you@somewhere.dev"
      aria-label="Email address"
      class="flex-1 min-w-0 px-4 py-3 border border-line rounded bg-paper text-ink font-[inherit] text-nav outline-none focus:border-accent transition-colors"
    />
    <button
      type="submit"
      class="px-5 py-3 bg-ink text-paper border-none rounded font-[inherit] text-nav font-medium cursor-pointer flex-none min-h-11 hover:bg-accent transition-colors mobile:w-full"
    >
      Subscribe
    </button>
  </form>
</section>
